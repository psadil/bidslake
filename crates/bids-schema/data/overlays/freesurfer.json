  "rules": {
    "tabular_data": {
      "freesurfer": {
        "freesurfer_aseg": {
          "selectors": [
            "datatype == \"anat\"",
            "extension == \".stats\"",
            "suffix == \"segstats\""
          ],
          "additional_columns": "allowed",
          "columns": {
            "Index__fs_aseg": "optional",
            "SegId__fs_aseg": "optional",
            "NVoxels__fs_aseg": "optional",
            "Volume_mm3__fs_aseg": "optional",
            "StructName__fs_aseg": "optional",
            "normMean__fs_aseg": "optional",
            "normStdDev__fs_aseg": "optional",
            "normMin__fs_aseg": "optional",
            "normMax__fs_aseg": "optional",
            "normRange__fs_aseg": "optional"
          }
        },
        "freesurfer_aparc": {
          "selectors": [
            "datatype == \"anat\"",
            "extension == \".stats\"",
            "suffix == \"parcstats\""
          ],
          "additional_columns": "allowed",
          "columns": {
            "StructName__fs_aparc": "optional",
            "NumVert__fs_aparc": "optional",
            "SurfArea__fs_aparc": "optional",
            "GrayVol__fs_aparc": "optional",
            "ThickAvg__fs_aparc": "optional",
            "ThickStd__fs_aparc": "optional",
            "MeanCurv__fs_aparc": "optional",
            "GausCurv__fs_aparc": "optional",
            "FoldInd__fs_aparc": "optional",
            "CurvInd__fs_aparc": "optional"
          }
        },
        "freesurfer_measures": {
          "selectors": [
            "suffix == \"fsmeasures\""
          ],
          "additional_columns": "allowed",
          "columns": {
            "BrainSegVol__fs_measures": "optional",
            "BrainSegVolNotVent__fs_measures": "optional",
            "CortexVol__fs_measures": "optional",
            "lhCortexVol__fs_measures": "optional",
            "rhCortexVol__fs_measures": "optional",
            "CerebralWhiteMatterVol__fs_measures": "optional",
            "lhCerebralWhiteMatterVol__fs_measures": "optional",
            "rhCerebralWhiteMatterVol__fs_measures": "optional",
            "SubCortGrayVol__fs_measures": "optional",
            "TotalGrayVol__fs_measures": "optional",
            "SupraTentorialVol__fs_measures": "optional",
            "MaskVol__fs_measures": "optional",
            "eTIV__fs_measures": "optional",
            "WhiteSurfArea__fs_measures": "optional",
            "MeanThickness__fs_measures": "optional",
            "NumVert__fs_measures": "optional",
            "lhSurfaceHoles__fs_measures": "optional",
            "rhSurfaceHoles__fs_measures": "optional",
            "SurfaceHoles__fs_measures": "optional"
          }
        },
        "freesurfer_labels": {
          "selectors": [
            "extension == \".ctab\"",
            "suffix == \"fslabels\""
          ],
          "additional_columns": "allowed",
          "columns": {
            "seg_id__fs_labels": "optional",
            "struct_name__fs_labels": "optional",
            "r__fs_labels": "optional",
            "g__fs_labels": "optional",
            "b__fs_labels": "optional",
            "a__fs_labels": "optional"
          }
        }
      }
